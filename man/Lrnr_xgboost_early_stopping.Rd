% Generated by hand for the package-local learner.
\name{Lrnr_xgboost_early_stopping}
\alias{Lrnr_xgboost_early_stopping}
\title{XGBoost Learner with Early Stopping}
\usage{
Lrnr_xgboost_early_stopping$new(
  nrounds = 500,
  validation_fraction = 0.2,
  early_stopping_rounds = 25,
  seed = 1,
  nthread = 1,
  ...
)
}
\arguments{
\item{nrounds}{Maximum number of boosting rounds considered before early stopping.}

\item{validation_fraction}{Fraction of the training sample reserved for the internal validation split.}

\item{early_stopping_rounds}{Number of validation rounds without improvement before stopping.}

\item{seed}{Random seed used for the internal validation split.}

\item{nthread}{Number of threads used by \code{xgboost}.}

\item{...}{Additional arguments passed to \code{\link[xgboost]{xgb.train}}.}
}
\value{
An \code{sl3::Lrnr_base} learner that selects the number of boosting rounds by
early stopping and then refits on the full training sample.
}
\description{
Package-local \code{sl3} learner for \code{xgboost} models with an internal
validation split. The learner uses early stopping to choose the number of
boosting rounds, then retrains the final model on the full training data with
the selected iteration count.
}
\details{
This learner is used by \code{\link{get_autoML}} to avoid manually fixing
\code{nrounds} in the default boosted-tree candidates.
}
